{
    "name": "rosalana/safepoint",
    "description": "Generate Typescript representation of Laravel models, routes and actions.",
    "type": "library",
    "keywords": [
        "laravel",
        "package",
        "rosalana",
        "typescript",
        "inertia",
        "php",
        "routes"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "michaelbany",
            "email": "mobany526@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/console": "^12.0",
        "illuminate/filesystem": "^12.0",
        "illuminate/routing": "^12.0",
        "laravel/ranger": "^0.1.0",
        "laravel/surveyor": "^0.1.0",
        "phpstan/phpdoc-parser": "^2.3"
    },
    "require-dev": {
        "inertiajs/inertia-laravel": "^2.0",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Rosalana\\Safepoint\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "generate": "bash -c 'php vendor/bin/testbench migrate --database=sqlite --ansi && php -d DB_CONNECTION=sqlite vendor/bin/testbench safepoint:generate --ansi \"$@\"' --"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rosalana\\Safepoint\\Providers\\RosalanaSafepointServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
